# Railway Postgres connection string
DATABASE_URL=postgresql://postgres:password@hostname:5432/railway

# Resend API key (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx

# Verified sender in Resend
FROM_EMAIL=The Ebb & Flow <news@yourdomain.com>

# Tip / reply inbox (Resend Reply-To). Replies to “just hit reply” land here.
# REPLY_TO_EMAIL=newsroom@yourdomain.com

# Public base URL of this service (Railway app URL)
APP_URL=https://your-app.up.railway.app

# Optional: send only this issue UUID (otherwise latest ready issue)
# ISSUE_ID=

# Optional: dry-run (render + log, do not call Resend)
# DRY_RUN=true

# Optional: limit recipients while testing
# MAX_RECIPIENTS=3

# HTTP server port (Railway sets PORT automatically)
PORT=3000

# Required in production for POST /cron/send and /cron/auto-draft
CRON_SECRET=replace-me
# Weekly send scheduler inside the web process (Mondays 15:00 UTC). Default true.
# If you also run a dedicated Railway Cron service (railway.cron.toml), set this
# to false on the *web* service so only one runner fires.
# A Postgres advisory lock still prevents double-send if both are enabled.
# WEEKLY_CRON_ENABLED=true

# Resend webhook signing secret (Dashboard → Webhooks → whsec_...)
# Point the webhook at POST /api/webhooks/resend for email.bounced + email.complained
# RESEND_WEBHOOK_SECRET=whsec_...

# Soft caps for admin context file uploads (PDF/DOCX/etc.)
# CONTEXT_UPLOAD_MAX_BYTES=26214400
# CONTEXT_UPLOAD_MAX_CHARS=1500000

# Required for /admin login (subscriber page stays public)
ADMIN_PASSWORD=choose-a-strong-password

# Claude API — auto-write newsletter copy from story source notes
# Always uses Claude Fable 5 (claude-fable-5); model is not configurable.
# Prefer AI_KEY (underscore). AI-KEY / ANTHROPIC_API_KEY also work.
# AI fact-check uses Anthropic web_search (must be available on the API key).
AI_KEY=sk-ant-...
# Auto-draft from newest unused transcripts (admin + /cron/auto-draft)
AUTO_DRAFT_FROM_FINDINGS=true
# Also draft on every web boot (default false — saves Claude spend)
# AUTO_DRAFT_ON_BOOT=false
# FINDINGS_BATCH_SIZE=6   # max topics per auto-draft / propose batch
# When true, saving a story with source_notes rewrites the whole issue
# ANTHROPIC_AUTO_WRITE=true

# Ketchikan weather (Open-Meteo) + NOAA tides autofill defaults
# MARINE_LATITUDE=55.3422
# MARINE_LONGITUDE=-131.6461
# MARINE_TIMEZONE=America/Juneau
# TIDE_STATION_ID=9450460
