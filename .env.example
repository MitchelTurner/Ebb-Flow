# Railway Postgres connection string
DATABASE_URL=postgresql://postgres:password@hostname:5432/railway

# Resend API key (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx

# Verified sender in Resend
FROM_EMAIL=The Ebb & Flow <news@yourdomain.com>

# Public base URL of this service (Railway app URL)
APP_URL=https://your-app.up.railway.app

# Optional: send only this issue UUID (otherwise latest ready issue)
# ISSUE_ID=

# Optional: dry-run (render + log, do not call Resend)
# DRY_RUN=true

# Optional: limit recipients while testing
# MAX_RECIPIENTS=3

# HTTP server port (Railway sets PORT automatically)
PORT=3000

# Optional: protect POST /cron/send
# CRON_SECRET=replace-me

# Required for /admin login (subscriber page stays public)
ADMIN_PASSWORD=choose-a-strong-password

# Claude API — auto-write newsletter copy from story source notes
# Always uses Claude Fable 5 (claude-fable-5); model is not configurable.
# Prefer AI_KEY (underscore). AI-KEY / ANTHROPIC_API_KEY also work.
AI_KEY=sk-ant-...
# Auto-draft a review issue from newest unused transcripts (findings fallback) on boot / cron
AUTO_DRAFT_FROM_FINDINGS=true
# FINDINGS_BATCH_SIZE=6
# When true, saving a story with source_notes rewrites the whole issue
# ANTHROPIC_AUTO_WRITE=true

# Ketchikan weather (Open-Meteo) + NOAA tides autofill defaults
# MARINE_LATITUDE=55.3422
# MARINE_LONGITUDE=-131.6461
# MARINE_TIMEZONE=America/Juneau
# TIDE_STATION_ID=9450460

